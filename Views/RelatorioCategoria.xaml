<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAPPMinhasCompras.Views.RelatorioCategoria"
                       Title="Relatório por Categoria">

    <VerticalStackLayout Padding="10" Spacing="10" BackgroundColor="#eeeeee">
        <!-- Cabeçalho -->
        <Label Text="Total Gasto por Categoria" 
               FontAttributes="Bold" 
               FontSize="22" 
               HorizontalOptions="Center"
               TextColor="#333"/>

        <!-- Lista de categorias -->
        <CollectionView x:Name="lst_relatorio" Margin="0,10" SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" CornerRadius="5" BackgroundColor="White" HasShadow="True">
                        <Grid ColumnDefinitions="*,*">
                            <Label Text="{Binding Categoria}" FontAttributes="Bold" FontSize="16" TextColor="#555"/>
                            <Label Text="{Binding TotalGasto, StringFormat='{}{0:C}'}" 
                                   HorizontalTextAlignment="End" 
                                   FontAttributes="Bold" 
                                   FontSize="16" 
                                   TextColor="#2e8b57"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>